VERSION 5.8 ;
DIVIDERCHAR "/" ;
BUSBITCHARS "[]" ;
DESIGN interchange_top ;
UNITS DISTANCE MICRONS 1000 ;
DIEAREA ( 0 0 ) ( 20000 20000 ) ;
ROW row_0 coreSite 1000 1000 N DO 180 BY 1 STEP 100 1000 ;
COMPONENTS 1 ;
- U1 INV_X1 + PLACED ( 2000 1000 ) N ;
END COMPONENTS
PINS 1 ;
- IN + NET DATA + DIRECTION INPUT + USE SIGNAL + PLACED ( 1000 5000 ) N ;
END PINS
NETS 1 ;
- DATA ( PIN IN ) ( U1 A ) + ROUTED M2 0 ( 2000 1000 ) ( 3000 1000 ) ;
END NETS
BLOCKAGES 1 ;
- PLACEMENT ( 5000 5000 ) ( 5500 5700 ) ;
END BLOCKAGES
SPECIALNETS 1 ;
- VDD + USE POWER + PROPERTY XCI_POWER_ID "ring_vdd" + ROUTED M1 0 ( 100 100 ) ( 19900 19900 ) ;
END SPECIALNETS
END DESIGN
